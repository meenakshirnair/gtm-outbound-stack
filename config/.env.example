# Copy this file to .env in the project root and fill in your real keys.
# Never commit the real .env file.

APIFY_TOKEN=your_apify_token_here
APOLLO_API_KEY=your_apollo_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Only needed for step5_sheet_output.py
GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/service-account.json
OUTBOUND_SHEET_NAME=GTM Outbound Demo

# Only needed for step5_gmail_drafts.py (uses OAuth, credentials.json lives in this folder)
